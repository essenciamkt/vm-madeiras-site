---
export interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;

const navigationItems = [
    { href: "/", label: "Início" },
    { href: "/produtos", label: "Produtos" },
    { href: "/#quem-somos", label: "Quem Somos" },
    { href: "/#parceiros", label: "Parceiros" },
    { href: "/#contato", label: "Contato" },
];
---

<nav
    id="main-navigation"
    class={`navbar ${className}`}
    role="navigation"
    aria-label="Navegação principal"
>
    <div class="navbar-container">
        <div class="navbar-content">
            <!-- Logo -->
            <div class="navbar-brand">
                <a
                    href="#inicio"
                    class="brand-link"
                    aria-label="VM Madeiras - Página inicial"
                >
                    <img
                        src="/img/logo-sem-fundo.png"
                        alt="VM Madeiras Logo"
                        class="w-auto h-16 object-contain"
                        style="mix-blend-mode: multiply;"
                    />
                </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="navbar-menu" role="menubar">
                {
                    navigationItems.map((item) => (
                        <a
                            href={item.href}
                            class="nav-link"
                            role="menuitem"
                            data-section={item.href.slice(1)}
                        >
                            {item.label}
                        </a>
                    ))
                }
            </div>

            <!-- CTA Button -->
            <div class="navbar-cta">
                <a
                    href="#contato"
                    class="cta-button"
                    role="button"
                    aria-label="Solicitar orçamento"
                >
                    <span>Solicitar Orçamento</span>
                </a>
            </div>

            <!-- Mobile menu button -->
            <div class="navbar-mobile-toggle">
                <button
                    class="mobile-menu-button"
                    aria-label="Abrir menu de navegação"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                    data-mobile-toggle
                >
                    <span class="hamburger-icon" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                </button>
            </div>
        </div>

        <!-- Mobile Navigation Menu -->
        <div
            id="mobile-menu"
            class="mobile-menu"
            role="menu"
            aria-label="Menu de navegação mobile"
            aria-hidden="true"
        >
            <div class="mobile-menu-content">
                {
                    navigationItems.map((item) => (
                        <a
                            href={item.href}
                            class="mobile-nav-link"
                            role="menuitem"
                            data-section={item.href.slice(1)}
                        >
                            {item.label}
                        </a>
                    ))
                }
                <div class="mobile-cta">
                    <a
                        href="#contato"
                        class="mobile-cta-button"
                        role="button"
                        aria-label="Solicitar orçamento"
                    >
                        Solicitar Orçamento
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<style>
    /* Navigation Styles */
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }

    .navbar-container {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1rem;
    }

    @media (min-width: 640px) {
        .navbar-container {
            padding: 0 1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .navbar-container {
            padding: 0 2rem;
        }
    }

    .navbar-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 5rem;
    }

    /* Brand */
    .navbar-brand {
        flex-shrink: 0;
    }

    .brand-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        transition: transform 0.2s ease;
    }

    .brand-link:hover {
        transform: scale(1.02);
    }

    .brand-icon {
        width: 2.5rem;
        height: 2.5rem;
        background: linear-gradient(
            135deg,
            var(--color-primary-600),
            var(--color-primary-700)
        );
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(169, 58, 51, 0.3);
    }

    .brand-text {
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--color-text-primary);
        line-height: 1.2;
    }

    /* Desktop Navigation */
    .navbar-menu {
        display: none;
        align-items: center;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .navbar-menu {
            display: flex;
        }
    }

    .nav-link {
        color: var(--color-text-secondary);
        font-weight: 500;
        padding: 0.5rem 0.75rem;
        border-radius: 0.375rem;
        text-decoration: none;
        transition: all 0.3s ease;
        position: relative;
        font-size: 0.9rem;
    }

    .nav-link:hover {
        color: var(--color-primary-600);
        background-color: var(--color-primary-50);
    }

    .nav-link.active {
        color: var(--color-primary-700);
        background-color: var(--color-primary-50);
    }

    /* CTA Button */
    .navbar-cta {
        display: none;
    }

    @media (min-width: 768px) {
        .navbar-cta {
            display: block;
        }
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.5rem;
        background: linear-gradient(
            135deg,
            var(--color-primary-600),
            var(--color-primary-700)
        );
        color: white;
        font-weight: 600;
        border-radius: 0.5rem;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(169, 58, 51, 0.3);
        transition: all 0.3s ease;
        font-size: 0.9rem;
    }

    .cta-button:hover {
        background: linear-gradient(
            135deg,
            var(--color-primary-700),
            var(--color-primary-800)
        );
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(169, 58, 51, 0.4);
    }

    /* Mobile Toggle */
    .navbar-mobile-toggle {
        display: block;
    }

    @media (min-width: 768px) {
        .navbar-mobile-toggle {
            display: none;
        }
    }

    .mobile-menu-button {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.5rem;
        border: none;
        background: none;
        color: var(--color-text-secondary);
        border-radius: 0.375rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .mobile-menu-button:hover {
        color: var(--color-primary-600);
        background-color: var(--color-primary-50);
    }

    .hamburger-icon {
        display: flex;
        flex-direction: column;
        width: 1.5rem;
        height: 1.5rem;
        justify-content: space-around;
    }

    .hamburger-icon span {
        display: block;
        height: 2px;
        width: 100%;
        background-color: currentColor;
        border-radius: 1px;
        transition: all 0.3s ease;
    }

    .mobile-menu-button[aria-expanded="true"]
        .hamburger-icon
        span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
    }

    .mobile-menu-button[aria-expanded="true"]
        .hamburger-icon
        span:nth-child(2) {
        opacity: 0;
    }

    .mobile-menu-button[aria-expanded="true"]
        .hamburger-icon
        span:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -6px);
    }

    /* Mobile Menu */
    .mobile-menu {
        display: none;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    @media (max-width: 767px) {
        .mobile-menu[aria-hidden="false"] {
            display: block;
        }
    }

    .mobile-menu-content {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .mobile-nav-link {
        color: var(--color-text-secondary);
        font-weight: 500;
        padding: 1rem 0.75rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .mobile-nav-link:hover,
    .mobile-nav-link.active {
        color: var(--color-primary-600);
        background-color: var(--color-primary-50);
    }

    .mobile-cta {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border-light);
    }

    .mobile-cta-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 1rem 1.5rem;
        background: linear-gradient(
            135deg,
            var(--color-primary-600),
            var(--color-primary-700)
        );
        color: white;
        font-weight: 600;
        border-radius: 0.5rem;
        text-decoration: none;
        box-shadow: 0 4px 12px rgba(169, 58, 51, 0.3);
        transition: all 0.3s ease;
    }

    .mobile-cta-button:hover {
        background: linear-gradient(
            135deg,
            var(--color-primary-700),
            var(--color-primary-800)
        );
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(169, 58, 51, 0.4);
    }

    /* Scroll behavior */
    .navbar.scrolled {
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    /* Smooth animations */
    * {
        -webkit-tap-highlight-color: transparent;
    }

    /* Focus styles for accessibility */
    .nav-link:focus,
    .mobile-nav-link:focus,
    .cta-button:focus,
    .mobile-cta-button:focus,
    .mobile-menu-button:focus {
        outline: 2px solid var(--color-primary-600);
        outline-offset: 2px;
    }
</style>

<script>
    class Navigation {
        private nav: HTMLElement | null;
        private mobileToggle: HTMLElement | null;
        private mobileMenu: HTMLElement | null;
        private navLinks: NodeListOf<HTMLElement>;

        constructor() {
            this.nav = document.querySelector("#main-navigation");
            this.mobileToggle = document.querySelector("[data-mobile-toggle]");
            this.mobileMenu = document.querySelector("#mobile-menu");
            this.navLinks = document.querySelectorAll("[data-section]");

            this.init();
        }

        init(): void {
            if (!this.nav || !this.mobileToggle || !this.mobileMenu) return;

            this.setupMobileMenu();
            this.setupScrollBehavior();
            this.setupActiveLinks();
            this.setupKeyboardNavigation();
        }

        setupMobileMenu(): void {
            if (!this.mobileToggle || !this.mobileMenu || !this.nav) return;

            this.mobileToggle.addEventListener("click", () =>
                this.toggleMobileMenu(),
            );

            // Close mobile menu when clicking outside
            document.addEventListener("click", (e: Event) => {
                const target = e.target as HTMLElement;
                if (!this.nav?.contains(target) && this.isMobileMenuOpen()) {
                    this.closeMobileMenu();
                }
            });

            // Close mobile menu on nav link click
            this.mobileMenu
                .querySelectorAll("a")
                .forEach((link: HTMLAnchorElement) => {
                    link.addEventListener("click", () =>
                        this.closeMobileMenu(),
                    );
                });
        }

        setupScrollBehavior(): void {
            let ticking = false;

            window.addEventListener("scroll", () => {
                if (!ticking) {
                    requestAnimationFrame(() => {
                        this.handleScroll();
                        ticking = false;
                    });
                    ticking = true;
                }
            });
        }

        setupActiveLinks(): void {
            const observerOptions: IntersectionObserverInit = {
                root: null,
                rootMargin: "-20% 0px -80% 0px",
                threshold: 0,
            };

            const observer = new IntersectionObserver(
                (entries: IntersectionObserverEntry[]) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            this.setActiveLink(entry.target.id);
                        }
                    });
                },
                observerOptions,
            );

            // Observe all sections
            document
                .querySelectorAll("section[id], main[id], div[id]")
                .forEach((section) => {
                    observer.observe(section);
                });
        }

        setupKeyboardNavigation(): void {
            // Handle Escape key to close mobile menu
            document.addEventListener("keydown", (e: KeyboardEvent) => {
                if (e.key === "Escape" && this.isMobileMenuOpen()) {
                    this.closeMobileMenu();
                    (this.mobileToggle as HTMLElement)?.focus();
                }
            });
        }

        toggleMobileMenu(): void {
            const isOpen = this.isMobileMenuOpen();

            if (isOpen) {
                this.closeMobileMenu();
            } else {
                this.openMobileMenu();
            }
        }

        openMobileMenu(): void {
            if (!this.mobileMenu || !this.mobileToggle) return;

            this.mobileMenu.setAttribute("aria-hidden", "false");
            this.mobileToggle.setAttribute("aria-expanded", "true");

            // Focus first link for accessibility
            const firstLink = this.mobileMenu.querySelector(
                "a",
            ) as HTMLAnchorElement;
            if (firstLink) {
                setTimeout(() => firstLink.focus(), 150);
            }
        }

        closeMobileMenu(): void {
            if (!this.mobileMenu || !this.mobileToggle) return;

            this.mobileMenu.setAttribute("aria-hidden", "true");
            this.mobileToggle.setAttribute("aria-expanded", "false");
        }

        isMobileMenuOpen(): boolean {
            return this.mobileMenu?.getAttribute("aria-hidden") === "false";
        }

        handleScroll(): void {
            if (!this.nav) return;

            const scrolled = window.scrollY > 50;
            this.nav.classList.toggle("scrolled", scrolled);
        }

        setActiveLink(sectionId: string): void {
            this.navLinks.forEach((link: HTMLElement) => {
                const isActive = link.dataset.section === sectionId;
                link.classList.toggle("active", isActive);
            });
        }
    }

    // Initialize navigation when DOM is ready
    document.addEventListener("DOMContentLoaded", () => {
        new Navigation();
    });
</script>
