---
import { ArrowRight } from "lucide-astro";
import { produtos } from "../data/produtos.js";

export interface Props {
    id?: string;
}

const { id = "produtos" } = Astro.props;
---

<section id={id} class="py-24 bg-gray-50 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0">
        <div
            class="absolute top-1/4 left-1/4 w-64 h-64 bg-gray-200/20 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-gray-200/20 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-gray-100 text-primary-700 text-sm font-semibold rounded-full mb-4"
            >
                Nossos Produtos
            </span>
            <h2
                class="text-4xl md:text-5xl font-bold text-gradient-primary mb-6"
            >
                Produtos de <span class="text-primary-600">Qualidade</span>
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
                Oferecemos uma linha completa de produtos para construção civil
                e marcenaria, todos com certificação ambiental e a qualidade que
                você já conhece.
            </p>
        </div>

        <!-- Products Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
        >
            {
                produtos.map((produto) => (
                    <div class="bg-white rounded-2xl shadow-xl overflow-hidden h-full">
                        <img
                            src={produto.image}
                            alt={`${produto.title} em Teresópolis - Madeireira VM Madeiras & Cia com certificação IBAMA e 50 anos de tradição`}
                            class="w-full h-48 object-cover"
                        />
                        <div class="p-6">
                            <h3 class="text-2xl font-bold text-gray-900 mb-2">
                                {produto.shortTitle}
                            </h3>
                            <p class="text-gray-700 mb-4">
                                {produto.description}
                            </p>
                            <a
                                href={`/linha/${produto.id}`}
                                class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-semibold rounded-lg shadow-md hover:from-primary-700 hover:to-gray-800 transform hover:scale-105 transition-all duration-300"
                            >
                                Ver Detalhes
                                <ArrowRight class="ml-2 w-5 h-5" />
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- CTA Section -->
        <div class="mt-16 text-center">
            <div
                class="bg-gradient-to-r from-gray-100 to-gray-200 backdrop-blur-sm rounded-3xl p-8 border border-white/30 shadow-xl"
            >
                <h3 class="text-2xl font-bold text-gray-900 mb-4">
                    Precisa de um orçamento personalizado?
                </h3>
                <p class="text-gray-700 mb-8 max-w-2xl mx-auto">
                    Nossa equipe está preparada para esclarecer suas dúvidas e
                    garantir um ótimo atendimento. Entre em contato conosco para
                    receber seu orçamento sem compromisso.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                        href="#contato"
                        class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-semibold rounded-xl shadow-lg hover:from-primary-700 hover:to-gray-800 transform hover:scale-105 transition-all duration-300"
                    >
                        Solicitar Orçamento
                        <ArrowRight class="ml-2 w-5 h-5" />
                    </a>
                    <a
                        href="/produtos"
                        class="inline-flex items-center px-8 py-4 bg-white text-primary-600 font-semibold rounded-xl shadow-lg border border-primary-200 hover:bg-gray-50 transform hover:scale-105 transition-all duration-300"
                    >
                        Ver Todos os Produtos
                        <ArrowRight class="ml-2 w-5 h-5" />
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
