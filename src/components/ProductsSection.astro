---
import FeatureCard from "../components/FeatureCard.astro";

export interface Props {
    id?: string;
}

const { id = "produtos" } = Astro.props;

const produtos = [
    {
        title: "Portas",
        description:
            "Portas de madeira de alta qualidade para residências e estabelecimentos comerciais.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Portas+de+Madeira",
    },
    {
        title: "Madeira de Telhado",
        description:
            "Estruturas para telhados com madeira tratada e certificada para maior durabilidade.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12l4-4 4 4m0 6H4m0 0l4-4m-4 4l4-4"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Madeira+Telhado",
    },
    {
        title: "Madeira Plástica",
        description:
            "Alternativa sustentável com resistência à umidade e pragas, ideal para áreas externas.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Madeira+Plástica",
    },
    {
        title: "Decks e Assoalhos",
        description:
            "Pisos em madeira natural e tratada para ambientes internos e externos.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Decks+Assoalhos",
    },
    {
        title: "Ferragens",
        description:
            "Acessórios e componentes metálicos para construção e marcenaria.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Ferragens",
    },
    {
        title: "Esquadrias",
        description:
            "Janelas, portas e caixilhos em madeira de diversos tamanhos e estilos.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Esquadrias",
    },
    {
        title: "Máquinas",
        description:
            "Equipamentos e máquinas para carpintaria e marcenaria profissional.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Máquinas",
    },
    {
        title: "Ferramentas",
        description:
            "Ferramentas manuais e elétricas para carpintaria e construção civil.",
        icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 011-1h1a2 2 0 100-4H7a1 1 0 01-1-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
    </svg>`,
        image: "https://placehold.co/400x300?text=Ferramentas",
    },
];
---

<section
    id={id}
    class="py-24 bg-gradient-to-br from-gray-50 to-primary-50/30 relative overflow-hidden"
>
    <!-- Background decoration -->
    <div class="absolute inset-0">
        <div
            class="absolute top-1/4 left-1/4 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-primary-200/20 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-primary-100 text-primary-800 text-sm font-semibold rounded-full mb-4"
            >
                Nossos Produtos
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                Produtos de <span class="text-primary-600">Qualidade</span>
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-500 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
                Oferecemos uma linha completa de produtos para construção civil
                e marcenaria, todos com certificação ambiental e a qualidade que
                você já conhece.
            </p>
        </div>

        <!-- Products Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
        >
            {
                produtos.map((produto) => (
                    <FeatureCard
                        title={produto.title}
                        description={produto.description}
                        icon={produto.icon}
                        image={produto.image}
                        href="#contato"
                        class="h-full"
                    />
                ))
            }
        </div>

        <!-- Environmental Certification Banner -->
        <div class="mt-20">
            <div
                class="bg-gradient-to-r from-green-600 to-green-700 rounded-3xl p-8 lg:p-12 text-white text-center relative overflow-hidden"
            >
                <div class="absolute inset-0 bg-black/10"></div>
                <div class="relative z-10">
                    <div class="flex justify-center mb-6">
                        <div
                            class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="text-3xl font-bold mb-4">
                        Certificação Ambiental
                    </h3>
                    <p class="text-xl opacity-90 mb-8 max-w-3xl mx-auto">
                        Nossos produtos são provenientes de <strong
                            >extração de manejo</strong
                        >. Possuímos licença ambiental e registro do IBAMA, com
                        a emissão de DOF de acordo com a legislação vigente no
                        Brasil.
                    </p>
                    <div
                        class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center"
                    >
                        <div class="bg-white/10 rounded-2xl p-6">
                            <h4 class="font-bold text-lg mb-2">
                                Licença IBAMA
                            </h4>
                            <p class="opacity-80">
                                Extração certificada e legal
                            </p>
                        </div>
                        <div class="bg-white/10 rounded-2xl p-6">
                            <h4 class="font-bold text-lg mb-2">DOF Emitido</h4>
                            <p class="opacity-80">
                                Documento de origem florestal
                            </p>
                        </div>
                        <div class="bg-white/10 rounded-2xl p-6">
                            <h4 class="font-bold text-lg mb-2">
                                Linha Ecológica
                            </h4>
                            <p class="opacity-80">
                                Eucalipto de reflorestamento
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Decorative elements -->
                <div
                    class="absolute -top-8 -right-8 w-32 h-32 bg-white/5 rounded-full"
                >
                </div>
                <div
                    class="absolute -bottom-8 -left-8 w-24 h-24 bg-white/5 rounded-full"
                >
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <div class="mt-16 text-center">
            <div
                class="bg-white/60 backdrop-blur-sm rounded-3xl p-8 border border-white/30 shadow-xl"
            >
                <h3 class="text-2xl font-bold text-gray-900 mb-4">
                    Precisa de um orçamento personalizado?
                </h3>
                <p class="text-gray-700 mb-8 max-w-2xl mx-auto">
                    Nossa equipe está preparada para esclarecer suas dúvidas e
                    garantir um ótimo atendimento. Entre em contato conosco para
                    receber seu orçamento sem compromisso.
                </p>
                <a
                    href="#contato"
                    class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-xl shadow-lg hover:from-primary-600 hover:to-primary-700 transform hover:scale-105 transition-all duration-300"
                >
                    Solicitar Orçamento
                    <svg
                        class="ml-2 w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>
