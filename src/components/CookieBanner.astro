---

---

<!-- Banner simples de cookies -->
<div id="cookie-banner" class="fixed inset-x-0 bottom-0 z-40 hidden">
  <div class="max-w-5xl mx-auto px-4 pb-4">
    <div class="bg-white rounded-lg shadow-xl p-4 md:p-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3 border border-gray-200">
      <p class="text-sm text-gray-700">
        Usamos cookies para personalizar conteúdos e melhorar a sua experiência.
      </p>
      <div class="flex items-center gap-3">
        <button id="open-config" class="px-4 py-2 rounded-lg bg-gray-200 text-gray-800 font-medium hover:bg-gray-300 transition-colors">
          Configurar
        </button>
        <button id="accept-simple" class="px-4 py-2 rounded-lg bg-primary-600 text-white font-medium hover:bg-primary-700 transition-colors">
          Entendi e aceito
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal de configuração de cookies -->
<div
  id="cookie-modal"
  class="fixed inset-0 bg-black/30 flex items-center justify-center z-50 hidden"
>
  <div class="bg-white rounded-lg max-w-md w-full mx-4 shadow-xl">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <div class="flex items-center space-x-3">
        <div
          class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center"
        >
          <svg
            class="w-5 h-5 text-red-600"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
              clip-rule="evenodd"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">
            Configurações de cookies
          </h3>
          <p class="text-sm text-gray-500">Valorizamos sua privacidade</p>
        </div>
      </div>
      <button id="close-modal" class="text-gray-400 hover:text-gray-600">
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Content -->
    <div class="p-6">
      <p class="text-gray-600 mb-6">
        Utilizamos cookies para melhorar sua experiência em nosso site,
        personalizar conteúdo e analisar nosso tráfego.
        <a
          href="/politicas-de-privacidade"
          class="text-primary-600 hover:underline"
          >Saiba mais sobre nossa política de privacidade</a
        >
      </p>

      <!-- Cookie Types -->
      <div class="space-y-4">
        <!-- Cookies essenciais -->
        <div
          class="flex items-center justify-between p-4 bg-gray-50 rounded-lg"
        >
          <div class="flex-1">
            <div class="flex items-center space-x-2 mb-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <h4 class="font-medium text-gray-900">Cookies essenciais</h4>
              <span
                class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full"
                >Sempre ativo</span
              >
            </div>
            <p class="text-sm text-gray-600">
              Necessários para o funcionamento básico do site
            </p>
          </div>
        </div>

        <!-- Cookies de estatística -->
        <div
          class="flex items-center justify-between p-4 bg-gray-50 rounded-lg"
        >
          <div class="flex-1">
            <div class="flex items-center space-x-2 mb-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <h4 class="font-medium text-gray-900">Cookies de estatística</h4>
            </div>
            <p class="text-sm text-gray-600">
              Nos ajudam a entender como você usa nosso site
            </p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="analytics-toggle" class="sr-only peer" />
            <div
              class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"
            >
            </div>
          </label>
        </div>

        <!-- Cookies de marketing -->
        <div
          class="flex items-center justify-between p-4 bg-gray-50 rounded-lg"
        >
          <div class="flex-1">
            <div class="flex items-center space-x-2 mb-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <h4 class="font-medium text-gray-900">Cookies de marketing</h4>
            </div>
            <p class="text-sm text-gray-600">
              Para personalizar anúncios e conteúdo
            </p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="marketing-toggle" class="sr-only peer" />
            <div
              class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"
            >
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="p-6 border-t border-gray-200">
      <div class="flex flex-col space-y-3">
        <button
          id="confirm-config"
          class="w-full bg-primary-600 text-white py-3 px-4 rounded-lg font-medium hover:bg-primary-700 transition-colors"
        >
          Confirmar configurações
        </button>
        <div class="flex space-x-3">
          <button
            id="accept-all"
            class="flex-1 bg-gray-900 text-white py-2 px-4 rounded-lg font-medium hover:bg-gray-800 transition-colors"
          >
            Aceitar todos
          </button>
          <button
            id="reject-all"
            class="flex-1 bg-gray-200 text-gray-700 py-2 px-4 rounded-lg font-medium hover:bg-gray-300 transition-colors"
          >
            Rejeitar todos
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const banner = document.getElementById("cookie-banner");
    const openConfigBtn = document.getElementById("open-config");
    const acceptSimpleBtn = document.getElementById("accept-simple");

    const modal = document.getElementById("cookie-modal");
    const closeBtn = document.getElementById("close-modal");
    const confirmBtn = document.getElementById("confirm-config");
    const acceptAllBtn = document.getElementById("accept-all");
    const rejectAllBtn = document.getElementById("reject-all");
    const analyticsToggle = document.getElementById("analytics-toggle");
    const marketingToggle = document.getElementById("marketing-toggle");

    // helper removido: as checagens foram feitas inline para evitar reclamações de tipagem
    const showBanner = () => banner && banner.classList.remove("hidden");
    const hideBanner = () => banner && banner.classList.add("hidden");
    const openModal = () => modal && modal.classList.remove("hidden");
    const closeModal = (showBasic = true) => {
      if (modal) modal.classList.add("hidden");
      if (showBasic && !localStorage.getItem("cookiesAccepted")) {
        showBanner();
      }
    };

    // Exibir primeiro o banner simples se ainda não houve decisão
    if (!localStorage.getItem("cookiesAccepted")) {
      showBanner();
      if (modal) modal.classList.add("hidden");
    } else {
      hideBanner();
      if (modal) modal.classList.add("hidden");
    }

    // Ações do banner simples
    if (openConfigBtn) {
      openConfigBtn.addEventListener("click", () => {
        hideBanner();
        openModal();
      });
    }

    if (acceptSimpleBtn) {
      acceptSimpleBtn.addEventListener("click", () => {
        const preferences = {
          essential: true,
          analytics: true,
          marketing: true,
        };
        localStorage.setItem("cookiesAccepted", "all");
        localStorage.setItem("cookiePreferences", JSON.stringify(preferences));
        hideBanner();
        if (modal) modal.classList.add("hidden");
      });
    }

    // Fechar modal (sem confirmar) volta para o banner simples
    if (closeBtn) {
      closeBtn.addEventListener("click", () => closeModal(true));
    }

    // Confirmar configurações
    if (confirmBtn) {
      confirmBtn.addEventListener("click", () => {
        const preferences = {
          essential: true,
          analytics: analyticsToggle instanceof HTMLInputElement ? analyticsToggle.checked : false,
          marketing: marketingToggle instanceof HTMLInputElement ? marketingToggle.checked : false,
        };
        localStorage.setItem("cookiesAccepted", "configured");
        localStorage.setItem("cookiePreferences", JSON.stringify(preferences));
        hideBanner();
        closeModal(false);
      });
    }

    // Aceitar todos
    if (acceptAllBtn) {
      acceptAllBtn.addEventListener("click", () => {
        const preferences = {
          essential: true,
          analytics: true,
          marketing: true,
        };
        localStorage.setItem("cookiesAccepted", "all");
        localStorage.setItem("cookiePreferences", JSON.stringify(preferences));
        hideBanner();
        closeModal(false);
      });
    }

    // Rejeitar todos (exceto essenciais)
    if (rejectAllBtn) {
      rejectAllBtn.addEventListener("click", () => {
        const preferences = {
          essential: true,
          analytics: false,
          marketing: false,
        };
        localStorage.setItem("cookiesAccepted", "essential");
        localStorage.setItem("cookiePreferences", JSON.stringify(preferences));
        hideBanner();
        closeModal(false);
      });
    }

    // Fechar modal ao clicar fora - volta para o banner simples
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          closeModal(true);
        }
      });
    }
  });
</script>