---
import { ExternalLink, MapPin, Navigation } from "lucide-astro";

export interface Props {
    address?: string;
    width?: string;
    height?: string;
    class?: string;
}

const {
    address = "Av. Alberto Torres, 500 - Alto - Teresópolis - RJ",
    width = "100%",
    height = "400px",
    class: className = "",
} = Astro.props;

// Encode the address for URL
const encodedAddress = encodeURIComponent(address);

// Google Maps embed URL (free, no API key required)
const embedUrl = `https://www.google.com/maps?q=${encodedAddress}&output=embed`;

// Fallback search URL
const searchUrl = `https://www.google.com/maps/search/${encodedAddress}`;
---

<div class={`google-map-container ${className}`}>
    <!-- Google Maps Embed -->
    <iframe
        src={embedUrl}
        width={width}
        height={height}
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Mapa de ${address}`}
        class="rounded-lg shadow-lg w-full"></iframe>

    <!-- Action buttons -->
    <div class="mt-4 flex flex-col sm:flex-row gap-3 justify-center">
        <a
            href={searchUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-[#7D2B2D] text-white rounded-lg hover:bg-[#6B2426] transition-colors"
        >
            <MapPin class="w-5 h-5" />
            Ver no Google Maps
        </a>

        <a
            href={`https://www.google.com/maps/dir//${encodedAddress}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
            <Navigation class="w-5 h-5" />
            Como Chegar
        </a>
    </div>
</div>

<style>
    .google-map-container {
        position: relative;
    }

    .google-map-container iframe {
        width: 100%;
        min-height: 300px;
    }

    @media (max-width: 768px) {
        .google-map-container iframe {
            height: 250px;
        }
    }
</style>
