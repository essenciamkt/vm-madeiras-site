---
import { FileText, Truck, Heart, MapPin, ChevronRight } from "lucide-astro";

export interface Props {
    id?: string;
}

const { id = "quem-somos" } = Astro.props;
---

<section id={id} class="py-24 bg-white relative overflow-hidden">
    <!-- Background elements -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-gray-50/50 to-wood-50/50"
    >
    </div>
    <div
        class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gray-100/30 to-transparent"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Content -->
            <div class="space-y-8">
                <div>
                    <span
                        class="inline-block px-4 py-2 bg-gray-100 text-gray-700 text-sm font-semibold rounded-full mb-4"
                    >
                        Nossa História
                    </span>
                    <h2
                        class="text-4xl md:text-5xl font-bold text-gradient-primary leading-tight"
                    >
                        Quem <span class="text-primary-600">Somos</span>
                    </h2>
                    <div
                        class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mt-4"
                    >
                    </div>
                </div>

                <div class="space-y-6">
                    <p class="text-lg text-gray-700 leading-relaxed">
                        Nossa história se inicia há aproximadamente 70 anos.
                        Quando um jovem imigrante português, visita Teresópolis
                        e resolve por aqui se estabelecer. Inicialmente atuando
                        no comércio de alimentos. Com uma pequena mercearia,
                        constitui família e aprofunda suas raízes nesta bela
                        cidade. Até que, por volta de 1975, troca de ramo, dando
                        início a sua atuação no comércio de madeiras e
                        complementos para construção. Deste empreendimento
                        inicial se desenvolve a segunda empresa, já contando com
                        a administração de seus sucessores. E assim chegamos
                        aqui.
                    </p>
                </div>

                <!-- Key Features -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start">
                    <div class="flex items-center space-x-3">
                        <div
                            class="w-10 h-10 min-w-[40px] min-h-[40px] bg-gray-100 border border-gray-200 rounded-lg flex items-center justify-center"
                        >
                            <FileText
                                size={28}
                                color="#7D2B2D"
                                class="w-7 h-7"
                            />
                        </div>
                        <div>
                            <h4 class="font-semibold text-gray-900">
                                DOF Emitido
                            </h4>
                            <p class="text-sm text-gray-600">
                                Documento de origem florestal
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center space-x-3">
                        <div
                            class="w-10 h-10 min-w-[40px] min-h-[40px] bg-gray-100 border border-gray-200 rounded-lg flex items-center justify-center"
                        >
                            <Truck size={28} color="#7D2B2D" class="w-7 h-7" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-gray-900">
                                Frota Própria
                            </h4>
                            <p class="text-sm text-gray-600">
                                Entrega rápida e garantida
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center space-x-3">
                        <div
                            class="w-10 h-10 min-w-[40px] min-h-[40px] bg-gray-100 border border-gray-200 rounded-lg flex items-center justify-center"
                        >
                            <Heart size={28} color="#7D2B2D" class="w-7 h-7" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-gray-900">
                                Compromisso e Cuidado
                            </h4>
                            <p class="text-sm text-gray-600">
                                Foco no desenvolvimento sustentável e respeito à
                                natureza
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl p-6 border border-gray-100">
                    <p class="text-gray-700 font-medium text-center">
                        <strong>Qualidade:</strong> esse é o nosso maior compromisso.
                    </p>
                </div>
            </div>

            <!-- Image placeholder -->
            <div class="relative">
                <div
                    class="aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl"
                >
                    <img
                        src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=professional%20lumber%20yard%20wood%20store%20in%20Teresópolis%20Brazil%20with%20mountains%20in%20background%2C%20stacks%20of%20quality%20wood%20planks%2C%20organized%20warehouse%2C%20modern%20building%2C%20Serra%20dos%20Órgãos%20mountains%2C%20professional%20lighting%2C%20high%20quality%20photography&image_size=portrait_4_3"
                        alt="VM Madeiras & Cia em Teresópolis"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                </div>

                <!-- Floating card -->
                <div
                    class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-xl border border-gray-100"
                >
                    <div class="flex items-center space-x-4">
                        <div
                            class="w-12 h-12 bg-gray-100 border border-gray-200 rounded-full flex items-center justify-center"
                        >
                            <MapPin size={24} color="#7D2B2D" />
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-900">
                                Teresópolis, RJ
                            </h4>
                            <p class="text-sm text-gray-600">
                                Uma das cidades mais belas do Brasil
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Teresópolis Section -->
        <div class="mt-24">
            <div class="text-center mb-12">
                <h3 class="text-3xl font-bold text-gray-900 mb-4">
                    Teresópolis
                </h3>
                <p class="text-lg text-gray-700 max-w-3xl mx-auto">
                    Localizada a 910 m do nível do mar, próximo a grandes
                    centros urbanos, Teresópolis destaca-se no cenário
                    brasileiro por suas belezas naturais, clima aconchegante e
                    população hospitaleira.
                </p>
            </div>

            <div
                class="bg-gradient-to-r from-gray-100 to-gray-200 rounded-3xl p-8 text-center"
            >
                <h4 class="text-4xl font-bold mb-4 text-gradient-primary">
                    Venha nos visitar!
                </h4>
                <p class="text-lg opacity-90 mb-6">
                    Estamos localizados na Av. Alberto Torres, 500 - Alto -
                    Teresópolis - RJ
                </p>
                <a
                    href="#contato"
                    class="inline-flex items-center px-8 py-4 bg-white text-gray-600 font-semibold rounded-xl hover:bg-gray-50 transform hover:scale-105 transition-all duration-300 shadow-lg"
                >
                    Como Chegar
                    <ChevronRight class="ml-2 w-5 h-5" />
                </a>
            </div>
        </div>
    </div>
</section>
