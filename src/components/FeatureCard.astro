---
import {
    Check,
    Star,
    TreePine,
    FileText,
    Truck,
    Heart,
    MapPin,
    Phone,
    Mail,
    Clock,
    Shield,
    Award,
    Users,
    Home,
    Menu,
    X,
    ChevronRight,
    ArrowRight,
} from "lucide-astro";

// Icon mapping for dynamic icon selection
const iconMap: Record<string, any> = {
    check: Check,
    star: Star,
    wood: TreePine,
    document: FileText,
    truck: Truck,
    heart: Heart,
    location: MapPin,
    phone: Phone,
    mail: Mail,
    clock: Clock,
    shield: Shield,
    award: Award,
    users: Users,
    home: Home,
    menu: Menu,
    x: X,
    "chevron-right": ChevronRight,
    "arrow-right": ArrowRight,
};

export interface Props {
    title: string;
    description?: string;
    icon?: string;
    image?: string;
    href?: string;
    class?: string;
}

const {
    title,
    description,
    icon,
    image,
    href,
    class: className = "",
} = Astro.props;
---

<div
    class={`
  group relative overflow-hidden rounded-2xl
  bg-white border border-gray-200/60
  shadow-sm hover:shadow-lg
  hover:border-gray-300/60
  transition-all duration-500 ease-out
  hover:scale-105 hover:-translate-y-1
  hover:shadow-primary-500/10
  ${className}
`}
>
    {
        image && (
            <div class="aspect-video overflow-hidden rounded-t-2xl">
                <img
                    src={image}
                    alt={title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy"
                />
            </div>
        )
    }

    <div class="p-6">
        {
            icon && iconMap[icon] && (
                <div class="mb-4 inline-flex items-center justify-center w-12 h-12 rounded-xl bg-white border border-gray-200 text-[#7D2B2D] shadow-lg">
                    {(() => {
                        const IconComponent = iconMap[icon];
                        return <IconComponent size={24} color="#7D2B2D" />;
                    })()}
                </div>
            )
        }

        <h3
            class="font-bold text-xl text-gray-900 mb-3 group-hover:text-primary-700 transition-colors duration-300"
        >
            {title}
        </h3>

        {
            description && (
                <p class="text-gray-600 leading-relaxed mb-4">{description}</p>
            )
        }

        {
            href && (
                <a
                    href={href}
                    class="inline-flex items-center text-primary-600 hover:text-primary-700 font-semibold transition-colors duration-300"
                    aria-label={`Saiba mais sobre ${title}`}
                >
                    Saiba mais
                    <ChevronRight class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
                </a>
            )
        }
    </div>

    <!-- Decorative gradient overlay -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-primary-500/3 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"
    >
    </div>
</div>
