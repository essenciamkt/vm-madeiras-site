---
export interface Props {
    name: string;
    class?: string;
    size?: number;
    color?: string;
    bg?: string;
}

const {
    name,
    class: className = "w-6 h-6",
    size,
    color = "#7D2B2D",
    bg = "",
} = Astro.props;

const finalClass = size
    ? `w-${size} h-${size} p-2 flex items-center justify-center`
    : `${className} p-2 flex items-center justify-center`;
---

<i
    data-lucide={name}
    class={finalClass}
    style={`color:${color};${bg ? `background:${bg};border-radius:0.75rem;` : ""}`}
></i>
