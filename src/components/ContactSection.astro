---
import {
    MapPin,
    Phone,
    Clock,
    ExternalLink,
    CheckCircle,
    ArrowLeftRight,
    MessageCircle,
} from "lucide-astro";
import { getProdutosForSelect } from "../data/produtos.js";

export interface Props {
    id?: string;
}

const { id = "contato" } = Astro.props;
const produtosSelect = getProdutosForSelect();
---

<section
    id={id}
    class="py-24 bg-gradient-to-br from-gray-900 to-gray-800 text-white relative overflow-hidden"
>
    <!-- Background decoration -->
    <div class="absolute inset-0">
        <div
            class="absolute top-1/4 left-1/4 w-64 h-64 bg-gray-100/10 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-gray-100/10 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-gray-100 text-gray-700 text-sm font-semibold rounded-full mb-4"
            >
                Entre em Contato
            </span>
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white">
                Fale Conosco
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
                Nossa equipe está preparada para esclarecer suas dúvidas e
                garantir um ótimo atendimento. Entre em contato conosco para
                receber seu orçamento sem compromisso.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <!-- Contact Information -->
            <div class="space-y-8">
                <div>
                    <h3 class="text-2xl font-bold mb-8">
                        Informações de Contato
                    </h3>

                    <!-- Address -->
                    <div class="flex items-start space-x-4 mb-6">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <MapPin class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">Endereço</h4>
                            <p class="text-gray-300">
                                Av. Alberto Torres, 500 - Alto
                            </p>
                            <p class="text-gray-300">Teresópolis - RJ</p>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="flex items-start space-x-4 mb-6">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <Phone class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">
                                Telefones
                            </h4>
                            <p class="text-gray-300">(21) 2642-4060</p>
                            <p class="text-gray-300 flex gap-1">
                                (21) 98132-0215
                                <svg
                                    class="inline size-5 align-text-bottom"
                                    version="1.1"
                                    id="Layer_1"
                                    xmlns="http://www.w3.org/2000/svg"
                                    xmlns:xlink="http://www.w3.org/1999/xlink"
                                    viewBox="0 0 418.135 418.135"
                                    xml:space="preserve"
                                >
                                    <g>
                                        <path
                                            style="fill:#7AD06D;"
                                            d="M198.929,0.242C88.5,5.5,1.356,97.466,1.691,208.02c0.102,33.672,8.231,65.454,22.571,93.536   L2.245,408.429c-1.191,5.781,4.023,10.843,9.766,9.483l104.723-24.811c26.905,13.402,57.125,21.143,89.108,21.631   c112.869,1.724,206.982-87.897,210.5-200.724C420.113,93.065,320.295-5.538,198.929,0.242z M323.886,322.197   c-30.669,30.669-71.446,47.559-114.818,47.559c-25.396,0-49.71-5.698-72.269-16.935l-14.584-7.265l-64.206,15.212l13.515-65.607   l-7.185-14.07c-11.711-22.935-17.649-47.736-17.649-73.713c0-43.373,16.89-84.149,47.559-114.819   c30.395-30.395,71.837-47.56,114.822-47.56C252.443,45,293.218,61.89,323.887,92.558c30.669,30.669,47.559,71.445,47.56,114.817   C371.446,250.361,354.281,291.803,323.886,322.197z"
                                        ></path>
                                        <path
                                            style="fill:#7AD06D;"
                                            d="M309.712,252.351l-40.169-11.534c-5.281-1.516-10.968-0.018-14.816,3.903l-9.823,10.008   c-4.142,4.22-10.427,5.576-15.909,3.358c-19.002-7.69-58.974-43.23-69.182-61.007c-2.945-5.128-2.458-11.539,1.158-16.218   l8.576-11.095c3.36-4.347,4.069-10.185,1.847-15.21l-16.9-38.223c-4.048-9.155-15.747-11.82-23.39-5.356   c-11.211,9.482-24.513,23.891-26.13,39.854c-2.851,28.144,9.219,63.622,54.862,106.222c52.73,49.215,94.956,55.717,122.449,49.057   c15.594-3.777,28.056-18.919,35.921-31.317C323.568,266.34,319.334,255.114,309.712,252.351z"
                                        ></path>
                                    </g>
                                </svg>
                            </p>
                        </div>
                    </div>

                    <!-- Business Hours -->
                    <div class="flex items-start space-x-4 mb-8">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <Clock class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">
                                Horário de Funcionamento
                            </h4>
                            <p class="text-gray-300">
                                Segunda a Sexta: 8h às 18h
                            </p>
                            <p class="text-gray-300">Sábado: 8h às 12h</p>
                            <p class="text-gray-300">
                                *Fechamos para almoço (12h às 13:30)
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Mapa Gratuito -->
                <div class="bg-gray-800 rounded-2xl p-6 border border-gray-700">
                    <h4 class="font-semibold text-lg mb-4">Como Chegar</h4>

                    <!-- Mapa usando Google Maps Embed (gratuito) -->
                    <div
                        class="aspect-video bg-gray-700 rounded-xl overflow-hidden"
                    >
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3664.8234567890123!2d-42.9752!3d-22.4194!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjLCsDI1JzA5LjgiUyA0MsKwNTgnMzAuNyJX!5e0!3m2!1spt-BR!2sbr!4v1640000000000!5m2!1spt-BR!2sbr&q=Av.+Alberto+Torres,+500+-+Alto+-+Teresópolis+-+RJ"
                            width="100%"
                            height="100%"
                            style="border:0; border-radius: 0.75rem;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Localização da empresa"></iframe>
                    </div>

                    <div class="flex flex-wrap gap-3 mt-4">
                        <a
                            href="https://maps.google.com/?q=Av.+Alberto+Torres,+500+-+Alto+-+Teresópolis+-+RJ"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white rounded-lg hover:from-primary-700 hover:to-gray-800 transition-colors duration-300 shadow-primary"
                        >
                            <ExternalLink class="w-4 h-4 mr-2" />
                            Abrir no Google Maps
                        </a>

                        <a
                            href="https://www.waze.com/pt-BR/live-map/directions?to=ll.-22.4194%2C-42.9752"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 transition-colors duration-300"
                        >
                            <svg
                                class="w-4 h-4 mr-2"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path
                                    d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                ></path>
                            </svg>
                            Abrir no Waze
                        </a>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div
                class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20"
            >
                <h3 class="text-2xl font-bold mb-8">Solicite seu Orçamento</h3>

                <form class="space-y-6" id="contact-form">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="nome"
                                class="block text-sm font-semibold mb-2"
                                >Nome *</label
                            >
                            <input
                                type="text"
                                id="nome"
                                name="nome"
                                required
                                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                                placeholder="Seu nome completo"
                            />
                        </div>
                        <div>
                            <label
                                for="telefone"
                                class="block text-sm font-semibold mb-2"
                                >Telefone *</label
                            >
                            <input
                                type="tel"
                                id="telefone"
                                name="telefone"
                                required
                                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                                placeholder="(21) 99999-9999"
                            />
                        </div>
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-semibold mb-2"
                            >E-mail</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                            placeholder="seu@email.com"
                        />
                    </div>

                    <div>
                        <label
                            for="produto"
                            class="block text-sm font-semibold mb-2"
                            >Produto de Interesse</label
                        >
                        <select
                            id="produto"
                            name="produto"
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                        >
                            <option value="" class="text-gray-900"
                                >Selecione um produto</option
                            >
                            {
                                produtosSelect.map((produto) => (
                                    <option
                                        value={produto.value}
                                        class="text-gray-900"
                                    >
                                        {produto.label}
                                    </option>
                                ))
                            }
                            <option value="outros" class="text-gray-900"
                                >Outros</option
                            >
                        </select>
                    </div>

                    <div>
                        <label
                            for="mensagem"
                            class="block text-sm font-semibold mb-2"
                            >Mensagem *</label
                        >
                        <textarea
                            id="mensagem"
                            name="mensagem"
                            rows="5"
                            required
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300 resize-none"
                            placeholder="Descreva seu projeto e necessidades..."
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full px-8 py-4 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-semibold rounded-xl shadow-lg hover:from-primary-700 hover:to-gray-800 transform hover:scale-[1.02] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:ring-offset-2 focus:ring-offset-gray-900"
                    >
                        Enviar Solicitação
                    </button>
                </form>
            </div>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div class="bg-white rounded-2xl p-6 border border-gray-100">
                <div
                    class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <CheckCircle class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-gray-900">
                    50 Anos de Tradição
                </h4>
                <p class="text-gray-400 text-sm">
                    Meio século servindo Teresópolis com qualidade
                </p>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-gray-100">
                <div
                    class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <CheckCircle class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-gray-900">
                    Certificação IBAMA
                </h4>
                <p class="text-gray-400 text-sm">
                    Produtos com licença ambiental e DOF
                </p>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-gray-100">
                <div
                    class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <ArrowLeftRight class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-gray-900">
                    Entrega Própria
                </h4>
                <p class="text-gray-400 text-sm">
                    Frota própria para entrega rápida e segura
                </p>
            </div>
        </div>
    </div>
</section>
