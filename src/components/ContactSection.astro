---
import {
    MapPin,
    Phone,
    Clock,
    Map,
    ExternalLink,
    CheckCircle,
    ArrowLeftRight,
    MessageCircle,
} from "lucide-astro";
import { getProdutosForSelect } from "../data/produtos.js";

export interface Props {
    id?: string;
}

const { id = "contato" } = Astro.props;
const produtosSelect = getProdutosForSelect();
---

<section
    id={id}
    class="py-24 bg-gradient-to-br from-gray-900 to-gray-800 text-white relative overflow-hidden"
>
    <!-- Background decoration -->
    <div class="absolute inset-0">
        <div
            class="absolute top-1/4 left-1/4 w-64 h-64 bg-primary-500/10 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-primary-500/10 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-primary-100 text-primary-700 text-sm font-semibold rounded-full mb-4"
            >
                Entre em Contato
            </span>
            <h2
                class="text-4xl md:text-5xl font-bold mb-6 text-gradient-primary"
            >
                Fale <span class="text-primary-400">Conosco</span>
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
                Nossa equipe está preparada para esclarecer suas dúvidas e
                garantir um ótimo atendimento. Entre em contato conosco para
                receber seu orçamento sem compromisso.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <!-- Contact Information -->
            <div class="space-y-8">
                <div>
                    <h3 class="text-2xl font-bold mb-8">
                        Informações de Contato
                    </h3>

                    <!-- Address -->
                    <div class="flex items-start space-x-4 mb-6">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <MapPin class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">Endereço</h4>
                            <p class="text-gray-300">
                                Av. Alberto Torres, 500 - Alto
                            </p>
                            <p class="text-gray-300">Teresópolis - RJ</p>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="flex items-start space-x-4 mb-6">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <Phone class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">
                                Telefones
                            </h4>
                            <p class="text-gray-300">(21) 2642-4060</p>
                            <p class="text-gray-300">
                                (21) 98132-0215
                                <MessageCircle
                                    class="inline w-5 h-5 ml-2 align-text-bottom text-green-400"
                                />
                            </p>
                        </div>
                    </div>

                    <!-- Business Hours -->
                    <div class="flex items-start space-x-4 mb-8">
                        <div
                            class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center flex-shrink-0"
                        >
                            <Clock class="w-6 h-6 text-primary-400" />
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-1">
                                Horário de Funcionamento
                            </h4>
                            <p class="text-gray-300">
                                Segunda a Sexta: 8h às 18h
                            </p>
                            <p class="text-gray-300">Sábado: 8h às 12h</p>
                            <p class="text-gray-300">
                                *Fechamos para almoço (12h às 13:30)
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Google Maps Placeholder -->
                <div class="bg-gray-800 rounded-2xl p-6 border border-gray-700">
                    <h4 class="font-semibold text-lg mb-4">Como Chegar</h4>
                    <div
                        class="aspect-video bg-gray-700 rounded-xl flex items-center justify-center"
                    >
                        <div class="text-center">
                            <Map class="w-12 h-12 text-gray-500 mx-auto mb-3" />
                            <p class="text-gray-400">Mapa Interativo</p>
                            <p class="text-sm text-gray-500">
                                Clique para abrir no Google Maps
                            </p>
                        </div>
                    </div>
                    <a
                        href="https://maps.google.com/?q=Av.+Alberto+Torres,+500+-+Alto+-+Teresópolis+-+RJ"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center mt-4 px-4 py-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white rounded-lg hover:from-primary-700 hover:to-primary-800 transition-colors duration-300 shadow-primary"
                    >
                        <ExternalLink class="w-4 h-4 mr-2" />
                        Abrir no Google Maps
                    </a>
                </div>
            </div>

            <!-- Contact Form -->
            <div
                class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20"
            >
                <h3 class="text-2xl font-bold mb-8">Solicite seu Orçamento</h3>

                <form class="space-y-6" id="contact-form">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="nome"
                                class="block text-sm font-semibold mb-2"
                                >Nome *</label
                            >
                            <input
                                type="text"
                                id="nome"
                                name="nome"
                                required
                                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                                placeholder="Seu nome completo"
                            />
                        </div>
                        <div>
                            <label
                                for="telefone"
                                class="block text-sm font-semibold mb-2"
                                >Telefone *</label
                            >
                            <input
                                type="tel"
                                id="telefone"
                                name="telefone"
                                required
                                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                                placeholder="(21) 99999-9999"
                            />
                        </div>
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-semibold mb-2"
                            >E-mail</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                            placeholder="seu@email.com"
                        />
                    </div>

                    <div>
                        <label
                            for="produto"
                            class="block text-sm font-semibold mb-2"
                            >Produto de Interesse</label
                        >
                        <select
                            id="produto"
                            name="produto"
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300"
                        >
                            <option value="" class="text-gray-900"
                                >Selecione um produto</option
                            >
                            {
                                produtosSelect.map((produto) => (
                                    <option
                                        value={produto.value}
                                        class="text-gray-900"
                                    >
                                        {produto.label}
                                    </option>
                                ))
                            }
                            <option value="outros" class="text-gray-900"
                                >Outros</option
                            >
                        </select>
                    </div>

                    <div>
                        <label
                            for="mensagem"
                            class="block text-sm font-semibold mb-2"
                            >Mensagem *</label
                        >
                        <textarea
                            id="mensagem"
                            name="mensagem"
                            rows="5"
                            required
                            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all duration-300 resize-none"
                            placeholder="Descreva seu projeto e necessidades..."
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full px-8 py-4 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-semibold rounded-xl shadow-lg hover:from-primary-700 hover:to-primary-800 transform hover:scale-[1.02] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:ring-offset-2 focus:ring-offset-gray-900"
                    >
                        Enviar Solicitação
                    </button>
                </form>
            </div>
        </div>

        <!-- Trust Indicators -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div
                class="bg-primary-50 rounded-2xl p-6 border border-primary-100"
            >
                <div
                    class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <CheckCircle class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-primary-700">
                    50 Anos de Tradição
                </h4>
                <p class="text-gray-400 text-sm">
                    Meio século servindo Teresópolis com qualidade
                </p>
            </div>

            <div
                class="bg-primary-50 rounded-2xl p-6 border border-primary-100"
            >
                <div
                    class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <CheckCircle class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-primary-700">
                    Certificação IBAMA
                </h4>
                <p class="text-gray-400 text-sm">
                    Produtos com licença ambiental e DOF
                </p>
            </div>

            <div
                class="bg-primary-50 rounded-2xl p-6 border border-primary-100"
            >
                <div
                    class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-4"
                >
                    <ArrowLeftRight class="w-6 h-6 text-primary-600" />
                </div>
                <h4 class="font-semibold text-lg mb-2 text-primary-700">
                    Entrega Própria
                </h4>
                <p class="text-gray-400 text-sm">
                    Frota própria para entrega rápida e segura
                </p>
            </div>
        </div>
    </div>
</section>
