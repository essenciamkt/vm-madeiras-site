---
import PrimaryButton from "../components/PrimaryButton.astro";

export interface Props {
    id?: string;
}

const { id = "inicio" } = Astro.props;
---

<section
    id={id}
    class="relative min-h-screen flex items-center justify-center overflow-hidden pt-32 lg:pt-40"
>
    <!-- Background with gradient mesh -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-primary-50 via-wood-50 to-neutral-50"
    >
        <div
            class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-20"
        >
        </div>
    </div>

    <!-- Hero Content -->
    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
    >
        <div class="space-y-8">
            <!-- Main Heading -->
            <div class="space-y-4">
                <h1
                    class="text-5xl md:text-7xl font-bold text-gray-900 leading-tight"
                >
                    <span class="block">VM Madeiras</span>
                    <span
                        class="block text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-800"
                    >
                        & Cia
                    </span>
                </h1>
                <div
                    class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto rounded-full"
                >
                </div>
            </div>

            <!-- Subtitle -->
            <p
                class="text-xl md:text-2xl text-gray-700 max-w-4xl mx-auto leading-relaxed"
            >
                <strong>50 anos de tradição</strong> fornecendo madeiras de qualidade
                em Teresópolis. Produtos com <span
                    class="text-primary-600 font-semibold">licença IBAMA</span
                > e
                <span class="text-primary-600 font-semibold">DOF</span> para sua
                segurança.
            </p>

            <!-- Key Benefits -->
            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto my-12"
            >
                <div
                    class="bg-white/60 backdrop-blur-sm rounded-2xl p-6 border border-white/30 shadow-lg"
                >
                    <div
                        class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mx-auto mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-900 mb-2">
                        Licença IBAMA
                    </h3>
                    <p class="text-gray-600 text-sm">
                        Produtos com certificação ambiental e DOF conforme
                        legislação
                    </p>
                </div>

                <div
                    class="bg-white/60 backdrop-blur-sm rounded-2xl p-6 border border-white/30 shadow-lg"
                >
                    <div
                        class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mx-auto mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-900 mb-2">
                        Entrega Própria
                    </h3>
                    <p class="text-gray-600 text-sm">
                        Frota própria para entrega rápida e eficiente
                    </p>
                </div>

                <div
                    class="bg-white/60 backdrop-blur-sm rounded-2xl p-6 border border-white/30 shadow-lg"
                >
                    <div
                        class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl flex items-center justify-center mx-auto mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-900 mb-2">
                        50 Anos
                    </h3>
                    <p class="text-gray-600 text-sm">
                        Tradição e confiança no mercado madeireiro
                    </p>
                </div>
            </div>

            <!-- CTA Buttons -->
            <div
                class="flex flex-col sm:flex-row gap-4 justify-center items-center"
            >
                <PrimaryButton
                    text="Solicitar Orçamento"
                    href="#contato"
                    size="lg"
                    variant="primary"
                />
                <PrimaryButton
                    text="Nossos Produtos"
                    href="#produtos"
                    size="lg"
                    variant="secondary"
                />
            </div>

            <!-- Social Proof -->
            <div class="mt-16 pt-8 pb-16 border-t border-white/30">
                <p class="text-gray-600 mb-6">
                    Confiança de profissionais da construção civil há meio
                    século
                </p>
                <div
                    class="flex justify-center items-center space-x-8 opacity-60 relative z-20"
                >
                    <div class="text-center">
                        <div class="text-2xl font-bold text-primary-600">
                            50+
                        </div>
                        <div class="text-sm text-gray-600">Anos</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-primary-600">
                            1000+
                        </div>
                        <div class="text-sm text-gray-600">Clientes</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-primary-600">
                            100%
                        </div>
                        <div class="text-sm text-gray-600">Licenciado</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 z-10">
        <div class="animate-bounce">
            <svg
                class="w-6 h-6 text-primary-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>
    </div>

    <style>
        /* Custom styles for Hero Section with new color palette */
        .from-primary-50 {
            --tw-gradient-from: var(--color-primary-50);
            --tw-gradient-to: rgb(253 242 242 / 0);
            --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to);
        }

        .via-wood-50 {
            --tw-gradient-to: rgb(250 248 243 / 0);
            --tw-gradient-stops: var(--tw-gradient-from), var(--color-wood-50),
                var(--tw-gradient-to);
        }

        .to-neutral-50 {
            --tw-gradient-to: var(--color-neutral-50);
        }

        .from-primary-600 {
            --tw-gradient-from: var(--color-primary-600);
            --tw-gradient-to: rgb(169 58 51 / 0);
            --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to);
        }

        .to-primary-800 {
            --tw-gradient-to: var(--color-primary-800);
        }

        .from-primary-500 {
            --tw-gradient-from: var(--color-primary-500);
            --tw-gradient-to: rgb(211 93 93 / 0);
            --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to);
        }

        .to-primary-700 {
            --tw-gradient-to: var(--color-primary-700);
        }

        .text-primary-600 {
            color: var(--color-primary-600);
        }

        .from-primary-500 {
            --tw-gradient-from: var(--color-primary-500);
        }

        .to-primary-600 {
            --tw-gradient-to: var(--color-primary-600);
        }

        /* Enhanced spacing for better visual hierarchy */
        section {
            scroll-margin-top: 5rem; /* Account for fixed navbar */
        }

        /* Smooth scroll behavior for anchor links */
        html {
            scroll-behavior: smooth;
        }

        /* Improved backdrop blur effect */
        .bg-white\/60 {
            background-color: rgba(255, 255, 255, 0.6);
        }

        .border-white\/30 {
            border-color: rgba(255, 255, 255, 0.3);
        }
    </style>
</section>
