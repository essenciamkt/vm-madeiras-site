---
export interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;
---

<footer class={`bg-gray-900 text-white py-16 ${className}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Company Info -->
            <div class="space-y-6">
                <div class="flex items-center space-x-3">
                    <a
                        href="#inicio"
                        class="brand-link"
                        aria-label="VM Madeiras - Página inicial"
                    >
                        <img
                            src="/img/logo-branco.png"
                            alt="VM Madeiras Logo"
                            class="w-auto h-16 object-contain"
                        />
                    </a>
                </div>
                <p class="text-gray-400 leading-relaxed">
                    50 anos fornecendo madeiras de qualidade em Teresópolis.
                    Tradição, honestidade e respeito ao cliente.
                </p>
                <div class="flex space-x-4">
                    <div
                        class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors duration-300 cursor-pointer"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors duration-300 cursor-pointer"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors duration-300 cursor-pointer"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                            ></path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="font-bold text-lg mb-6">Links Rápidos</h3>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="#inicio"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Início</a
                        >
                    </li>
                    <li>
                        <a
                            href="#quem-somos"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Quem Somos</a
                        >
                    </li>
                    <li>
                        <a
                            href="#produtos"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Produtos</a
                        >
                    </li>
                    <li>
                        <a
                            href="#parceiros"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Parceiros</a
                        >
                    </li>
                    <li>
                        <a
                            href="#contato"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Contato</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Products -->
            <div>
                <h3 class="font-bold text-lg mb-6">Nossos Produtos</h3>
                <ul class="space-y-3">
                    <li><span class="text-gray-400">Esquadrias</span></li>
                    <li>
                        <span class="text-gray-400">Madeira de Telhado</span>
                    </li>
                    <li>
                        <span class="text-gray-400">Decks e Assoalhos</span>
                    </li>
                    <li><span class="text-gray-400">Madeira Plástica</span></li>
                    <li><span class="text-gray-400">Ferramentas</span></li>
                </ul>
            </div>

            <!-- Contact Info -->
            <div>
                <h3 class="font-bold text-lg mb-6">Contato</h3>
                <div class="space-y-4">
                    <div class="flex items-start space-x-3">
                        <svg
                            class="w-5 h-5 text-primary-400 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <div class="text-gray-400 text-sm">
                            <p>Av. Alberto Torres, 500 - Alto</p>
                            <p>Teresópolis - RJ</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg
                            class="w-5 h-5 text-primary-400 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <div class="text-gray-400 text-sm">
                            <p>(21) 2642-4060</p>
                            <p>WhatsApp: 21 98132-0215</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg
                            class="w-5 h-5 text-primary-400 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        <div class="text-gray-400 text-sm">
                            <p>Seg-Sex: 8h às 18h</p>
                            <p>Sáb: 8h às 12h</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="border-t border-gray-800 mt-12 pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="text-gray-400 text-sm mb-4 md:mb-0">
                    <p>
                        &copy; 2024 VM Madeiras & Cia. Todos os direitos
                        reservados.
                    </p>
                </div>
                <div class="text-gray-400 text-sm">
                    <p>
                        Desenvolvido por <a
                            href="https://essenciamarketing.com.br/"
                            class="underline hover:text-primary-400 transition-colors duration-300"
                            target="_blank">Essência Marketing e Gestão</a
                        >
                    </p>
                </div>
            </div>

            <!-- Certifications -->
            <div class="mt-8 flex flex-wrap justify-center items-center gap-8">
                <div class="flex items-center space-x-2 text-primary-400">
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                        ></path>
                    </svg>
                    <span class="text-sm font-medium">DOF Certificado</span>
                </div>
                <div class="flex items-center space-x-2 text-primary-400">
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                        ></path>
                    </svg>
                    <span class="text-sm font-medium">50 Anos de Tradição</span>
                </div>
            </div>
        </div>
    </div>
</footer>
