---
import {
    MapPin,
    Phone,
    Clock,
    Mail,
    Facebook,
    Instagram,
    FileText,
    Star,
    MessageCircle,
} from "lucide-astro";

export interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class={`bg-gray-900 text-white py-16 ${className}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Company Info -->
            <div class="space-y-6">
                <div class="flex items-center space-x-3">
                    <a
                        href="/"
                        class="brand-link hover:text-primary-600 transition-colors"
                        aria-label="VM Madeiras - Página inicial"
                    >
                        <img
                            src="/img/logo-branco.png"
                            alt="VM Madeiras Logo"
                            class="w-auto h-16 object-contain"
                        />
                    </a>
                </div>
                <p class="text-gray-400 leading-relaxed">
                    50 anos fornecendo madeiras de qualidade em Teresópolis.
                    Tradição, honestidade e respeito ao cliente.
                </p>
                <div class="flex space-x-4">
                    <a
                        href="https://www.facebook.com/vmmadeirasecia"
                        target="_blank"
                        rel="noopener"
                        class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors duration-300"
                    >
                        <Facebook class="w-4 h-4 text-white" />
                    </a>
                    <a
                        href="https://www.instagram.com/vmmadeiras/"
                        target="_blank"
                        rel="noopener"
                        class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-primary-600 transition-colors duration-300"
                    >
                        <Instagram class="w-4 h-4 text-white" />
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="font-bold text-lg mb-6">Links Rápidos</h3>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Início</a
                        >
                    </li>
                    <li>
                        <a
                            href="#quem-somos"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Quem Somos</a
                        >
                    </li>
                    <li>
                        <a
                            href="#produtos"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Produtos</a
                        >
                    </li>
                    <li>
                        <a
                            href="#parceiros"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Parceiros</a
                        >
                    </li>
                    <li>
                        <a
                            href="#contato"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Contato</a
                        >
                    </li>
                    <li>
                        <a
                            href="/termos-de-uso"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Termos de Uso</a
                        >
                    </li>
                    <li>
                        <a
                            href="/politicas-de-privacidade"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Políticas de Privacidade</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Products -->
            <div>
                <h3 class="font-bold text-lg mb-6">Nossos Produtos</h3>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/linha/esquadrias"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Esquadrias</a
                        >
                    </li>
                    <li>
                        <a
                            href="/linha/madeira-telhado"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Madeira de Telhado</a
                        >
                    </li>
                    <li>
                        <a
                            href="/linha/decks-assoalhos"
                            class="text-gray-400 hover:text-primary-400 transition-colors duration-300"
                            >Decks e Assoalhos</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Contact Info -->
            <div>
                <h3 class="font-bold text-lg mb-6">Contato</h3>
                <div class="space-y-4">
                    <div class="flex items-start space-x-3">
                        <MapPin
                            class="w-5 h-5 text-primary-400 mt-0.5 flex-shrink-0"
                        />
                        <div class="text-gray-400 text-sm">
                            <p>Av. Alberto Torres, 500 - Alto</p>
                            <p>Teresópolis - RJ</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <Phone class="w-5 h-5 text-primary-400 flex-shrink-0" />
                        <div class="text-gray-400 text-sm">
                            <p>Telefone: (21) 2642-4060</p>
                            <p>
                                <a
                                    href="https://wa.me/5521981320215"
                                    target="_blank"
                                    rel="noopener"
                                    class="inline-flex items-center gap-1 hover:text-primary-400 transition-colors duration-300"
                                >
                                    WhatsApp: (21) 98132-0215
                                    <svg
                                        class="inline w-4 h-4 text-green-400 align-text-bottom"
                                        version="1.1"
                                        id="Layer_1"
                                        xmlns="http://www.w3.org/2000/svg"
                                        xmlns:xlink="http://www.w3.org/1999/xlink"
                                        viewBox="0 0 418.135 418.135"
                                        xml:space="preserve"
                                    >
                                        <g>
                                            <path
                                                style="fill:#7AD06D;"
                                                d="M198.929,0.242C88.5,5.5,1.356,97.466,1.691,208.02c0.102,33.672,8.231,65.454,22.571,93.536   L2.245,408.429c-1.191,5.781,4.023,10.843,9.766,9.483l104.723-24.811c26.905,13.402,57.125,21.143,89.108,21.631   c112.869,1.724,206.982-87.897,210.5-200.724C420.113,93.065,320.295-5.538,198.929,0.242z M323.886,322.197   c-30.669,30.669-71.446,47.559-114.818,47.559c-25.396,0-49.71-5.698-72.269-16.935l-14.584-7.265l-64.206,15.212l13.515-65.607   l-7.185-14.07c-11.711-22.935-17.649-47.736-17.649-73.713c0-43.373,16.89-84.149,47.559-114.819   c30.395-30.395,71.837-47.56,114.822-47.56C252.443,45,293.218,61.89,323.887,92.558c30.669,30.669,47.559,71.445,47.56,114.817   C371.446,250.361,354.281,291.803,323.886,322.197z"
                                            ></path>
                                            <path
                                                style="fill:#7AD06D;"
                                                d="M309.712,252.351l-40.169-11.534c-5.281-1.516-10.968-0.018-14.816,3.903l-9.823,10.008   c-4.142,4.22-10.427,5.576-15.909,3.358c-19.002-7.69-58.974-43.23-69.182-61.007c-2.945-5.128-2.458-11.539,1.158-16.218   l8.576-11.095c3.36-4.347,4.069-10.185,1.847-15.21l-16.9-38.223c-4.048-9.155-15.747-11.82-23.39-5.356   c-11.211,9.482-24.513,23.891-26.13,39.854c-2.851,28.144,9.219,63.622,54.862,106.222c52.73,49.215,94.956,55.717,122.449,49.057   c15.594-3.777,28.056-18.919,35.921-31.317C323.568,266.34,319.334,255.114,309.712,252.351z"
                                            ></path>
                                        </g>
                                    </svg>
                                </a>
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <Mail class="w-5 h-5 text-primary-400 flex-shrink-0" />
                        <div class="text-gray-400 text-sm">
                            <a
                                href="mailto:vmmadeiras@hotmail.com"
                                class="hover:text-primary-400 transition-colors duration-300"
                            >vmmadeiras@hotmail.com</a>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <Clock class="w-5 h-5 text-primary-400 flex-shrink-0" />
                        <div class="text-gray-400 text-sm">
                            <p>Seg-Sex: 8h às 18h</p>
                            <p>Sáb: 8h às 12h</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="border-t border-gray-800 mt-12 pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="text-gray-400 text-sm mb-4 md:mb-0">
                    <p>
                        &copy; {currentYear} VM Madeiras & Cia. Todos os direitos
                        reservados.
                    </p>
                    <p class="mt-1">CNPJ: 31.311.111/0001-42</p>
                </div>
                <div class="text-gray-400 text-sm">
                    <p>
                        Desenvolvido por <a
                            href="https://essenciamarketing.com.br/"
                            class="underline hover:text-primary-400 transition-colors duration-300"
                            target="_blank">Essência Marketing e Gestão</a
                        >
                    </p>
                </div>
            </div>

            <!-- Certifications -->
            <div class="mt-8 flex flex-wrap justify-center items-center gap-8">
                <div class="flex items-center space-x-2 text-primary-400">
                    <FileText class="w-5 h-5" />
                    <span class="text-sm font-medium">DOF Certificado</span>
                </div>
                <div class="flex items-center space-x-2 text-primary-400">
                    <Star class="w-5 h-5" />
                    <span class="text-sm font-medium">50 Anos de Tradição</span>
                </div>
            </div>
        </div>
    </div>
</footer>
