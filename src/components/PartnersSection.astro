// Função para formatar o telefone
const formatPhoneNumber = (phoneNumber: string) => {
    // Remove todos os caracteres não numéricos
    const cleaned = ('' + phoneNumber).replace(/\D/g, '');

    // Verifica se tem DDD (10 ou 11 dígitos)
    const match = cleaned.match(/^(\d{2})?(\d{4,5})(\d{4})$/);

    if (match) {
        const ddd = match[1] ? `(${match[1]}) ` : '';
        return `${ddd}${match[2]}-${match[3]}`;
    }
    return phoneNumber; // Retorna o original se não conseguir formatar
};

// Função para criar link de telefone
const createPhoneLink = (phoneNumber: string) => {
    const cleaned = ('' + phoneNumber).replace(/\D/g, '');
    return `tel:+55${cleaned}`;
};

// Função para criar link de email
const createEmailLink = (email: string) => {
    return `mailto:${email}`;
};

