---

<section id={id} class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-primary-100 text-primary-800 text-sm font-semibold rounded-full mb-4"
            >
                Nossa Rede
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
                Parceiros de <span class="text-primary-600">Confiança</span>
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
                Construímos uma sólida rede de parceiros ao longo de 50 anos,
                conectando profissionais qualificados e fornecedores de
                confiança.
            </p>
        </div>

        <!-- Tabs Navigation -->
        <div class="mb-12" x-data="{ activeTab: 'arquitetos' }">
            <div class="flex flex-wrap justify-center gap-4 mb-8">
                <button
                    @click="activeTab = 'arquitetos'"
                    :class="activeTab === 'arquitetos' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Arquitetos
                </button>
                <button
                    @click="activeTab = 'carpinteiros'"
                    :class="activeTab === 'carpinteiros' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Carpinteiros
                </button>
                <button
                    @click="activeTab = 'construtores'"
                    :class="activeTab === 'construtores' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Construtores
                </button>
                <button
                    @click="activeTab = 'fornecedores'"
                    :class="activeTab === 'fornecedores' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Fornecedores
                </button>
            </div>

            <!-- Arquitetos Tab -->
            <div
                x-show="activeTab === 'arquitetos'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-primary-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <svg
                            class="w-8 h-8 text-primary-600 mr-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                        Arquitetos Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            arquitetos.map((arquiteto) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {arquiteto.nome}
                                    </h4>
                                    <div class="space-y-1 text-sm text-gray-600">
                                        <div class="flex items-center">
                                            <svg
                                                class="w-4 h-4 mr-2 text-primary-500"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                                />
                                            </svg>
                                            {arquiteto.telefone}
                                        </div>
                                        <div class="flex items-center">
                                            <svg
                                                class="w-4 h-4 mr-2 text-primary-500"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                                />
                                            </svg>
                                            {arquiteto.email}
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Carpinteiros Tab -->
            <div
                x-show="activeTab === 'carpinteiros'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-wood-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <svg
                            class="w-8 h-8 text-primary-600 mr-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 011-1h1a2 2 0 100-4H7a1 1 0 01-1-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"
                            ></path>
                        </svg>
                        Carpinteiros Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            carpinteiros.map((carpinteiro) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {carpinteiro.nome}
                                    </h4>
                                    <div class="flex items-center text-sm text-gray-600">
                                        <svg
                                            class="w-4 h-4 mr-2 text-primary-500"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                            />
                                        </svg>
                                        {carpinteiro.telefone}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Construtores Tab -->
            <div
                x-show="activeTab === 'construtores'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <svg
                            class="w-8 h-8 text-green-600 mr-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                        Construtores Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            construtores.map((construtor) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {construtor.nome}
                                    </h4>
                                    <div class="space-y-1 text-sm text-gray-600">
                                        <div class="flex items-center">
                                            <svg
                                                class="w-4 h-4 mr-2 text-green-500"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                                />
                                            </svg>
                                            {construtor.telefone}
                                        </div>
                                        {construtor.contato && (
                                            <div class="flex items-center">
                                                <svg
                                                    class="w-4 h-4 mr-2 text-green-500"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                                    />
                                                </svg>
                                                {construtor.contato}
                                            </div>
                                        )}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Fornecedores Tab -->
            <div
                x-show="activeTab === 'fornecedores'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-purple-50 to-pink-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <svg
                            class="w-8 h-8 text-purple-600 mr-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                            ></path>
                        </svg>
                        Fornecedores Parceiros
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {
                            fornecedores.map((fornecedor) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                                    <h4 class="font-bold text-lg text-purple-700 mb-4">
                                        {fornecedor.categoria}
                                    </h4>
                                    <div class="flex flex-wrap gap-2">
                                        {fornecedor.marcas.map((marca) => (
                                            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm font-medium rounded-full">
                                                {marca}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <div class="mt-16 text-center">
            <div
                class="bg-gradient-to-r from-primary-600 to-primary-600 rounded-3xl p-8 lg:p-12 text-white"
            >
                <h3 class="text-3xl font-bold mb-4">
                    Quer fazer parte da nossa rede?
                </h3>
                <p class="text-xl opacity-90 mb-8 max-w-2xl mx-auto">
                    Se você é um profissional qualificado da construção civil ou
                    marcenaria, entre em contato conosco para conhecer nossas
                    parcerias.
                </p>
                <a
                    href="#contato"
                    class="inline-flex items-center px-8 py-4 bg-white text-primary-600 font-semibold rounded-xl hover:bg-gray-50 transform hover:scale-105 transition-all duration-300 shadow-lg"
                >
                    Tornar-se Parceiro
                    <svg
                        class="ml-2 w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>
