---

<section id={id} class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span
                class="inline-block px-4 py-2 bg-primary-100 text-primary-700 text-sm font-semibold rounded-full mb-4"
            >
                Nossa Rede
            </span>
            <h2
                class="text-4xl md:text-5xl font-bold text-gradient-primary mb-6"
            >
                Parceiros de <span class="text-primary-600">Confiança</span>
            </h2>
            <div
                class="w-16 h-1 bg-gradient-to-r from-primary-500 to-primary-700 mx-auto mb-6"
            >
            </div>
            <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
                Construímos uma sólida rede de parceiros ao longo de 50 anos,
                conectando profissionais qualificados e fornecedores de
                confiança.
            </p>
        </div>

        <!-- Tabs Navigation -->
        <div class="mb-12" x-data="{ activeTab: 'arquitetos' }">
            <div class="flex flex-wrap justify-center gap-4 mb-8">
                <button
                    @click="activeTab = 'arquitetos'"
                    :class="activeTab === 'arquitetos' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Arquitetos
                </button>
                <button
                    @click="activeTab = 'carpinteiros'"
                    :class="activeTab === 'carpinteiros' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Carpinteiros
                </button>
                <button
                    @click="activeTab = 'construtores'"
                    :class="activeTab === 'construtores' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Construtores
                </button>
                <button
                    @click="activeTab = 'engenheiros'"
                    :class="activeTab === 'engenheiros' ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'"
                    class="px-6 py-3 rounded-lg font-semibold transition-all duration-300"
                >
                    Engenheiros
                </button>
            </div>

            <!-- Arquitetos Tab -->
            <div
                x-show="activeTab === 'arquitetos'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-primary-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <Building class="w-8 h-8 mr-3" color="#7D2B2D" />
                        Arquitetos Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            arquitetos.map((arquiteto) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {arquiteto.nome}
                                    </h4>
                                    <div class="space-y-1 text-sm text-gray-600">
                                        <div class="flex items-center">
                                            <Phone
                                                class="w-4 h-4 mr-2"
                                                color="#7D2B2D"
                                            />
                                            {arquiteto.telefone}
                                        </div>
                                        <div class="flex items-center">
                                            <Mail
                                                class="w-4 h-4 mr-2"
                                                color="#7D2B2D"
                                            />
                                            {arquiteto.email}
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Carpinteiros Tab -->
            <div
                x-show="activeTab === 'carpinteiros'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-wood-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <Puzzle class="w-8 h-8 mr-3" color="#7D2B2D" />
                        Carpinteiros Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            carpinteiros.map((carpinteiro) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {carpinteiro.nome}
                                    </h4>
                                    <div class="flex items-center text-sm text-gray-600">
                                        <Phone
                                            class="w-4 h-4 mr-2"
                                            color="#7D2B2D"
                                        />
                                        {carpinteiro.telefone}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Construtores Tab -->
            <div
                x-show="activeTab === 'construtores'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-wood-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <Building class="w-8 h-8 mr-3" color="#7D2B2D" />
                        Construtores Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            construtores.map((construtor) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {construtor.nome}
                                    </h4>
                                    <div class="space-y-1 text-sm text-gray-600">
                                        <div class="flex items-center">
                                            <Phone
                                                class="w-4 h-4 mr-2"
                                                color="#7D2B2D"
                                            />
                                            {construtor.telefone}
                                        </div>
                                        {construtor.contato && (
                                            <div class="flex items-center">
                                                <Mail
                                                    class="w-4 h-4 mr-2"
                                                    color="#7D2B2D"
                                                />
                                                {construtor.contato}
                                            </div>
                                        )}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Engenheiros Tab -->
            <div
                x-show="activeTab === 'engenheiros'"
                x-transition
                class="space-y-6"
            >
                <div
                    class="bg-gradient-to-r from-primary-50 to-wood-50 rounded-2xl p-8"
                >
                    <h3
                        class="text-2xl font-bold text-gray-900 mb-6 flex items-center"
                    >
                        <Calculator class="w-8 h-8 mr-3" color="#7D2B2D" />
                        Engenheiros Parceiros
                    </h3>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            engenheiros.map((engenheiro) => (
                                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300">
                                    <h4 class="font-semibold text-gray-900 mb-2">
                                        {engenheiro.nome}
                                    </h4>
                                    <div class="space-y-1 text-sm text-gray-600">
                                        <div class="flex items-center">
                                            <Phone
                                                class="w-4 h-4 mr-2"
                                                color="#7D2B2D"
                                            />
                                            {engenheiro.telefone}
                                        </div>
                                        <div class="flex items-center">
                                            <Mail
                                                class="w-4 h-4 mr-2"
                                                color="#7D2B2D"
                                            />
                                            {engenheiro.email}
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <div class="mt-16 text-center">
            <div
                class="bg-gradient-to-r from-primary-600 to-primary-700 rounded-3xl p-8 lg:p-12 text-white"
            >
                <h3 class="text-3xl font-bold mb-4">
                    Quer fazer parte da nossa rede?
                </h3>
                <p class="text-xl opacity-90 mb-8 max-w-2xl mx-auto">
                    Se você é um profissional qualificado da construção civil ou
                    marcenaria, entre em contato conosco para conhecer nossas
                    parcerias.
                </p>
                <a
                    href="#contato"
                    class="inline-flex items-center px-8 py-4 bg-white text-primary-600 font-semibold rounded-xl hover:bg-primary-50 transform hover:scale-105 transition-all duration-300 shadow-lg"
                >
                    Tornar-se Parceiro
                    <ChevronRight class="ml-2 w-5 h-5" />
                </a>
            </div>
        </div>
    </div>
</section>
