---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import FeatureCard from "../../components/FeatureCard.astro";
import ArrowRight from "lucide-astro/ArrowRight";
import MessageCircle from "lucide-astro/MessageCircle";
import CheckCircle from "lucide-astro/CheckCircle";
import Home from "lucide-astro/Home";
import Phone from "lucide-astro/Phone";
import MapPin from "lucide-astro/MapPin";

// Generate static paths for all products
export async function getStaticPaths() {
    return [
        { params: { slug: "portas-madeira" } },
        { params: { slug: "madeira-telhado" } },
        { params: { slug: "decks-assoalhos" } },
        { params: { slug: "lambri-forro" } },
        { params: { slug: "madeiras-nobres" } },
        { params: { slug: "esquadrias" } },
        { params: { slug: "ferragens" } },
        { params: { slug: "compensados" } },
    ];
}

// Mock product data - in a real app, this would come from a CMS or database
const products = {
    "portas-madeira": {
        id: "portas-madeira",
        title: "Portas de Madeira",
        shortDescription:
            "Portas de madeira de alta qualidade para residências e estabelecimentos comerciais.",
        description:
            "Nossas portas de madeira são fabricadas com madeiras selecionadas e tratadas, oferecendo durabilidade, beleza e segurança para seu projeto. Disponíveis em diversos modelos, tamanhos e acabamentos.",
        price: "A partir de R$ 350,00",
        category: "Esquadrias",
        images: [
            "https://placehold.co/800x600?text=Porta+Principal",
            "https://placehold.co/800x600?text=Porta+Interna",
            "https://placehold.co/800x600?text=Porta+Dupla",
            "https://placehold.co/800x600?text=Detalhes",
        ],
        specifications: [
            { label: "Material", value: "Madeira maciça tratada" },
            { label: "Espessura", value: "35mm a 45mm" },
            { label: "Dimensões padrão", value: "210cm x 80cm / 210cm x 90cm" },
            { label: "Acabamento", value: "Natural, verniz ou tinta" },
            {
                label: "Garantia",
                value: "12 meses contra defeitos de fabricação",
            },
            {
                label: "Certificação",
                value: "IBAMA - Madeira de manejo sustentável",
            },
        ],
        features: [
            "Madeira de qualidade superior",
            "Tratamento contra pragas",
            "Diversos modelos disponíveis",
            "Instalação profissional",
            "Garantia de qualidade",
            "Certificação ambiental",
        ],
        applications: [
            "Residências",
            "Estabelecimentos comerciais",
            "Projetos arquitetônicos",
            "Reformas e construções",
        ],
    },
    "madeira-telhado": {
        id: "madeira-telhado",
        title: "Madeira para Telhado",
        shortDescription:
            "Madeiras estruturais de qualidade para construção de telhados e coberturas.",
        description:
            "Oferecemos madeiras estruturais selecionadas para telhados, com tratamento adequado e certificação IBAMA. Ideais para construções residenciais e comerciais que exigem resistência e durabilidade.",
        price: "A partir de R$ 25,00/m",
        category: "Estrutural",
        images: [
            "https://placehold.co/800x600?text=Vigas+Telhado",
            "https://placehold.co/800x600?text=Caibros",
            "https://placehold.co/800x600?text=Ripas",
            "https://placehold.co/800x600?text=Estrutura+Completa",
        ],
        specifications: [
            { label: "Tipos", value: "Vigas, caibros, ripas, terças" },
            { label: "Madeiras", value: "Pinus, Eucalipto, Peroba" },
            { label: "Tratamento", value: "Autoclave CCA" },
            { label: "Umidade", value: "Máximo 18%" },
            { label: "Certificação", value: "IBAMA e DOF" },
            { label: "Entrega", value: "Frota própria" },
        ],
        features: [
            "Madeira tratada em autoclave",
            "Baixa umidade",
            "Resistente a pragas",
            "Certificação ambiental",
            "Entrega rápida",
            "Preços competitivos",
        ],
        applications: [
            "Telhados residenciais",
            "Coberturas comerciais",
            "Galpões industriais",
            "Estruturas rurais",
        ],
    },
};

// Get the product slug from the URL
const { slug } = Astro.params;
const product = products[slug as keyof typeof products];

// If product doesn't exist, return 404
if (!product) {
    return Astro.redirect("/404");
}

// Related products (excluding current product)
const relatedProducts = Object.values(products)
    .filter((p) => p.id !== product.id)
    .slice(0, 3);

// SEO data
const title = `${product.title} - VM Madeiras & Cia`;
const description = product.shortDescription;
const keywords = `${product.title.toLowerCase()}, madeira, ${product.category.toLowerCase()}, teresópolis, vm madeiras`;
---

<Layout title={title} description={description} keywords={keywords}>
    <Navigation />

    <main class="pt-20">
        <!-- Breadcrumb -->
        <section class="bg-gray-50 py-4">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex" aria-label="Breadcrumb">
                    <ol class="flex items-center space-x-2 text-sm">
                        <li>
                            <a
                                href="/"
                                class="text-gray-500 hover:text-primary-600 transition-colors"
                            >
                                Início
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li>
                            <a
                                href="/#produtos"
                                class="text-gray-500 hover:text-primary-600 transition-colors"
                            >
                                Produtos
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li class="text-gray-900 font-medium">
                            {product.title}
                        </li>
                    </ol>
                </nav>
            </div>
        </section>

        <!-- Product Hero Section -->
        <section class="py-12 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                    <!-- Product Images -->
                    <div class="space-y-4">
                        <div
                            class="aspect-square overflow-hidden rounded-2xl bg-gray-100"
                        >
                            <img
                                src={product.images[0]}
                                alt={product.title}
                                class="w-full h-full object-cover"
                                id="main-image"
                            />
                        </div>
                        <div class="grid grid-cols-4 gap-4">
                            {
                                product.images.map((image, index) => (
                                    <button
                                        class="aspect-square overflow-hidden rounded-lg bg-gray-100 border-2 border-transparent hover:border-primary-300 transition-colors"
                                        onclick={`document.getElementById('main-image').src = '${image}'`}
                                    >
                                        <img
                                            src={image}
                                            alt={`${product.title} - Imagem ${index + 1}`}
                                            class="w-full h-full object-cover"
                                        />
                                    </button>
                                ))
                            }
                        </div>
                    </div>

                    <!-- Product Info -->
                    <div class="space-y-6">
                        <div>
                            <span
                                class="inline-block px-3 py-1 bg-primary-100 text-primary-800 text-sm font-semibold rounded-full mb-4"
                            >
                                {product.category}
                            </span>
                            <h1 class="text-4xl font-bold text-gray-900 mb-4">
                                {product.title}
                            </h1>
                            <p
                                class="text-xl text-gray-700 leading-relaxed mb-6"
                            >
                                {product.description}
                            </p>
                        </div>

                        <div class="border-t border-gray-200 pt-6">
                            <div class="flex items-center justify-between mb-6">
                                <div>
                                    <p
                                        class="text-3xl font-bold text-primary-600"
                                    >
                                        {product.price}
                                    </p>
                                    <p class="text-sm text-gray-500 mt-1">
                                        *Preços podem variar conforme
                                        especificações
                                    </p>
                                </div>
                            </div>

                            <!-- CTA Buttons -->
                            <div class="space-y-4">
                                <a
                                    href="#contato"
                                    class="w-full inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-semibold rounded-xl shadow-lg hover:from-primary-700 hover:to-primary-800 transform hover:scale-105 transition-all duration-300"
                                >
                                    Solicitar Orçamento
                                    <ArrowRight class="ml-2 w-5 h-5" />
                                </a>
                                <a
                                    href="https://wa.me/5521264240600?text=Olá! Gostaria de mais informações sobre: {product.title}"
                                    target="_blank"
                                    class="w-full inline-flex items-center justify-center px-8 py-4 bg-green-600 text-white font-semibold rounded-xl shadow-lg hover:bg-green-700 transform hover:scale-105 transition-all duration-300"
                                >
                                    <MessageCircle class="mr-2 w-5 h-5" />
                                    WhatsApp
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Product Details Tabs -->
        <section class="py-16 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                    <!-- Tab Navigation -->
                    <div class="border-b border-gray-200">
                        <nav class="flex space-x-8 px-8 pt-8" aria-label="Tabs">
                            <button
                                class="tab-button active py-4 px-1 border-b-2 border-primary-600 font-medium text-sm text-primary-600"
                                data-tab="specifications"
                            >
                                Especificações
                            </button>
                            <button
                                class="tab-button py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300"
                                data-tab="features"
                            >
                                Características
                            </button>
                            <button
                                class="tab-button py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300"
                                data-tab="applications"
                            >
                                Aplicações
                            </button>
                        </nav>
                    </div>

                    <!-- Tab Content -->
                    <div class="p-8">
                        <!-- Specifications Tab -->
                        <div id="specifications" class="tab-content">
                            <h3 class="text-2xl font-bold text-gray-900 mb-6">
                                Especificações Técnicas
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                {
                                    product.specifications.map((spec) => (
                                        <div class="flex justify-between items-center py-3 border-b border-gray-100">
                                            <span class="font-medium text-gray-700">
                                                {spec.label}:
                                            </span>
                                            <span class="text-gray-900">
                                                {spec.value}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>

                        <!-- Features Tab -->
                        <div id="features" class="tab-content hidden">
                            <h3 class="text-2xl font-bold text-gray-900 mb-6">
                                Características do Produto
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                {
                                    product.features.map((feature) => (
                                        <div class="flex items-center space-x-3">
                                            <CheckCircle class="w-5 h-5 text-green-600 flex-shrink-0" />
                                            <span class="text-gray-700">
                                                {feature}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>

                        <!-- Applications Tab -->
                        <div id="applications" class="tab-content hidden">
                            <h3 class="text-2xl font-bold text-gray-900 mb-6">
                                Aplicações Recomendadas
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                {
                                    product.applications.map((application) => (
                                        <div class="flex items-center space-x-3">
                                            <Home class="w-5 h-5 text-primary-600 flex-shrink-0" />
                                            <span class="text-gray-700">
                                                {application}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Related Products -->
        {
            relatedProducts.length > 0 && (
                <section class="py-16 bg-white">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="text-center mb-12">
                            <h2 class="text-3xl font-bold text-gray-900 mb-4">
                                Produtos Relacionados
                            </h2>
                            <p class="text-xl text-gray-600">
                                Outros produtos que podem interessar
                            </p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            {relatedProducts.map((relatedProduct) => (
                                <FeatureCard
                                    title={relatedProduct.title}
                                    description={
                                        relatedProduct.shortDescription
                                    }
                                    image={relatedProduct.images[0]}
                                    href={`/produto/${relatedProduct.id}`}
                                    class="h-full"
                                />
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

        <!-- Contact CTA Section -->
        <section
            id="contato"
            class="py-16 bg-gradient-to-br from-primary-50 to-primary-100"
        >
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-bold text-gray-900 mb-4">
                    Interessado neste produto?
                </h2>
                <p class="text-xl text-gray-700 mb-8">
                    Entre em contato conosco para receber um orçamento
                    personalizado
                </p>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto"
                >
                    <a
                        href="tel:+552126424060"
                        class="flex items-center justify-center px-6 py-4 bg-white text-gray-900 font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300"
                    >
                        <Phone class="mr-3 w-5 h-5 text-primary-600" />
                        (21) 2642-4060
                    </a>
                    <a
                        href="https://wa.me/5521981320215"
                        target="_blank"
                        class="flex items-center justify-center px-6 py-4 bg-green-600 text-white font-semibold rounded-xl shadow-lg hover:bg-green-700 transform hover:scale-105 transition-all duration-300"
                    >
                        <MessageCircle class="mr-3 w-5 h-5" />
                        WhatsApp
                    </a>
                </div>

                <div class="mt-8 text-gray-600">
                    <p class="flex items-center justify-center">
                        <MapPin class="mr-2 w-4 h-4" />
                        Av. Alberto Torres, 500 - Teresópolis, RJ
                    </p>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<script>
    // Tab functionality
    document.addEventListener("DOMContentLoaded", function () {
        const tabButtons = document.querySelectorAll(".tab-button");
        const tabContents = document.querySelectorAll(".tab-content");

        tabButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const targetTab = button.getAttribute("data-tab");

                // Remove active class from all buttons and contents
                tabButtons.forEach((btn) => {
                    btn.classList.remove(
                        "active",
                        "border-primary-600",
                        "text-primary-600",
                    );
                    btn.classList.add("border-transparent", "text-gray-500");
                });

                tabContents.forEach((content) => {
                    content.classList.add("hidden");
                });

                // Add active class to clicked button
                button.classList.add(
                    "active",
                    "border-primary-600",
                    "text-primary-600",
                );
                button.classList.remove("border-transparent", "text-gray-500");

                // Show target content
                const targetContent = document.getElementById(targetTab);
                if (targetContent) {
                    targetContent.classList.remove("hidden");
                }
            });
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
            anchor.addEventListener("click", function (e) {
                e.preventDefault();
                const target = document.querySelector(
                    this.getAttribute("href"),
                );
                if (target) {
                    const offsetTop = target.offsetTop - 80;
                    window.scrollTo({
                        top: offsetTop,
                        behavior: "smooth",
                    });
                }
            });
        });
    });
</script>

<style>
    .tab-button.active {
        border-color: var(--color-primary-600);
        color: var(--color-primary-600);
    }
</style>
