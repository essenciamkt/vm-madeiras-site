---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.core.min.css"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/css/glide.theme.min.css"
		/>
		<!-- Add the Glide.js script from CDN -->
		<script
			src="https://cdn.jsdelivr.net/npm/@glidejs/glide/dist/glide.min.js"
		></script>
	</head>
	<body>
		<slot />

		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				// Make sure the element exists before initializing
				const glideElement = document.querySelector(".glide");
				if (glideElement) {
					const glide = new Glide(".glide", {
						type: "carousel",
						startAt: 0,
						perView: 4,
						gap: 30,
						autoplay: 3000,
						hoverpause: true,
						breakpoints: {
							1024: {
								perView: 3,
							},
							768: {
								perView: 2,
							},
							480: {
								perView: 1,
							},
						},
					});

					glide.mount();
					console.log("Glide carousel initialized");
				} else {
					console.error("No .glide element found");
				}
			});
		</script>
	</body>
</html>
